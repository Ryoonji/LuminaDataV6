# LuminaData Enterprise v6.0 — Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM (Groq) ────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── PostgreSQL Database ───────────────────────────────────────
# For DBeaver: host=localhost, port=5433
# For Docker services: host=postgres, port=5432 (set automatically in docker-compose)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=luminadata
DB_USER=lumina_user
DB_PASSWORD=lumina_pass

# ── FalkorDB ──────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ── MCP Server ────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8765
MCP_SECRET=lumina_mcp_secret_2024

# ── Danswer RAG ───────────────────────────────────────────────
# Leave blank for static fallback (no Danswer container needed)
DANSWER_URL=http://localhost:3000
DANSWER_API_KEY=

# ── Optional: OpenRouter / Google (unused in v6.0) ───────────
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
